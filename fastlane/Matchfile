# Code-signing via fastlane match. Certificates & profiles live in a PRIVATE
# git repo (placeholder URL below — set MATCH_GIT_URL). CI runs read-only.
git_url(ENV["MATCH_GIT_URL"] || "https://github.com/your-org/certificates.git")
storage_mode("git")

type("appstore")
app_identifier([ENV["APP_IDENTIFIER"] || "com.example.daodejing"])

# Never let CI create/regenerate certificates — it only consumes them.
readonly(ENV["CI"] == "true")
