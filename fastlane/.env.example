# ─────────────────────────────────────────────────────────────────────────────
# Copy to `fastlane/.env` for local use, OR add each as a GitHub Actions secret.
# NOTHING here is committed (.env is gitignored). See docs/app-store-setup.md.
# ─────────────────────────────────────────────────────────────────────────────

# --- App identity (also settable per app) ---
APP_IDENTIFIER=com.example.daodejing
APP_SCHEME=DaodejingReader
APPLE_ID=you@example.com
TEAM_ID=ABCDE12345          # Apple Developer Team ID (Membership page)
ITC_TEAM_ID=               # App Store Connect team id (only if you belong to several)

# --- App Store Connect API key (Users & Access ▸ Integrations ▸ App Store Connect API) ---
APP_STORE_CONNECT_API_KEY_ID=XXXXXXXXXX
APP_STORE_CONNECT_API_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# base64 of the downloaded AuthKey_XXXX.p8 — generate with:
#   base64 -i AuthKey_XXXX.p8 | pbcopy
APP_STORE_CONNECT_API_KEY=BASE64_ENCODED_P8_CONTENTS

# --- fastlane match (private certificates repo) ---
MATCH_GIT_URL=https://github.com/your-org/certificates.git
MATCH_PASSWORD=your-match-encryption-passphrase
# Personal access token for the private certs repo, formatted as base64("user:token"):
#   echo -n "git-user:ghp_xxx" | base64
MATCH_GIT_BASIC_AUTHORIZATION=BASE64_USER_COLON_TOKEN

# --- CI keychain (any random string; created/destroyed per run by setup_ci) ---
KEYCHAIN_PASSWORD=ci-temp-password
