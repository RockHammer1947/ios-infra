# Shared formatting rules — run as a lint gate in CI, autoformat locally.
--swiftversion 6.0

--exclude Derived,.build,Tuist/Templates

--indent 4
--maxwidth 140
--wraparguments before-first
--wrapparameters before-first
--wrapcollections before-first
--self remove
--importgrouping testable-bottom
--commas inline
--trimwhitespace always

# Rules we intentionally disable
--disable redundantSelf,wrapMultilineStatementBraces
